{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "allowImportingTsExtensions": true,
    "allowArbitraryExtensions": true,

    "verbatimModuleSyntax": true,

    "strict": true,
    "skipLibCheck": true,

    "noEmit": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["vite/client"]
  },

  "include": [
    "src",
    "vite.config.ts"
  ]
}